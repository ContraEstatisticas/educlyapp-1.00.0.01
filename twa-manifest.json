    {
      "name": "Assistentes IA",
      "short_name": "IA",
      "url": "/assistentes",
      "icon": "https://SEU_DOMINIO_AQUI/pwa-192x192.png"
    }
  ],
  "generatorApp": "bubblewrap-cli",
  "webManifestUrl": "https://SEU_DOMINIO_AQUI/manifest.json",
  "fallbackType": "customtabs",
  "features": {
    "locationDelegation": {
      "enabled": false
    },
    "playBilling": {
